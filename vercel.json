{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.mariamadeira.com" }],
      "destination": "https://mariamadeira.com/:path*",
      "permanent": true
    }
  ]
}
